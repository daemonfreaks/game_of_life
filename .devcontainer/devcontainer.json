{
  "name": "Python3",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install --group dev",

  "customizations": {
    "vscode":{
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-containers",
        "github.vscode-github-actions",
        "openai.chatgpt"
      ]
    }
  }
}
